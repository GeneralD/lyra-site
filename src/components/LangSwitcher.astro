---
import { asLocale, copy, locales, type Locale } from "../i18n/translations";
import { localePath } from "../i18n/routes";

const locale = asLocale(Astro.currentLocale);
const t = copy[locale].langSwitcher;
const hrefFor = (l: Locale) => localePath(l, Astro.url.pathname);
const labels = { en: "EN", ja: "JA" } as const;
---

<nav
  aria-label={t.label}
  class="fixed right-4 top-4 z-50 flex overflow-hidden rounded-full border border-white/15 bg-black/40 font-mono text-xs backdrop-blur"
>
  {
    locales.map((l) => (
      <a
        href={hrefFor(l)}
        aria-current={l === locale ? "page" : undefined}
        class:list={[
          "px-3 py-1.5 tracking-widest transition",
          l === locale ? "bg-white/10 text-ink" : "text-faint hover:text-ink",
        ]}
      >
        {labels[l]}
      </a>
    ))
  }
</nav>
