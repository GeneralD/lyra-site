---
import { asLocale, copy } from "../i18n/translations";

const year = new Date().getFullYear();
const t = copy[asLocale(Astro.currentLocale)].footer;
---

<footer class="border-t border-white/10">
  <div class="mx-auto flex max-w-6xl flex-col items-center gap-6 px-6 py-12 sm:flex-row sm:justify-between">
    <div class="text-center sm:text-left">
      <p class="font-display text-sm font-bold uppercase tracking-widest text-ink">Lyra</p>
      <p class="mt-1 font-mono text-xs text-faint">
        {t.tagline}
      </p>
    </div>

    <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2 font-mono text-xs">
      <a href="https://github.com/GeneralD/lyra" class="text-muted transition hover:text-ink">GitHub</a>
      <a href="https://github.com/GeneralD/homebrew-tap" class="text-muted transition hover:text-ink">Homebrew Tap</a>
      <a href="https://github.com/GeneralD/lyra#readme" class="text-muted transition hover:text-ink">{t.docs}</a>
      <a href="https://github.com/GeneralD/lyra/blob/main/LICENSE" class="text-muted transition hover:text-ink">{t.license}</a>
    </nav>
  </div>

  <div class="border-t border-white/5 py-5 text-center font-mono text-xs text-faint">
    © {year} GeneralD · {t.madeWith}
  </div>
</footer>
