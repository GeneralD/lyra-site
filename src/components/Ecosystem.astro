---
// The Lyra family — one worldview across desktop, screen saver, and lock
// screen, with a "get the full set" recommendation. Copy lives in
// src/i18n/translations.ts; product names, repo URLs, and brew commands are
// locale-independent and live here.
import { asLocale, copy, type EcosystemKey } from "../i18n/translations";
import EcosystemMotif from "./EcosystemMotif.astro";

const products: readonly {
  readonly key: EcosystemKey;
  readonly name: string;
  readonly repo: string;
}[] = [
  { key: "desktop", name: "lyra", repo: "https://github.com/GeneralD/lyra" },
  {
    key: "screensaver",
    name: "lyra-screensaver",
    repo: "https://github.com/GeneralD/lyra-screensaver",
  },
  {
    key: "lockscreen",
    name: "lyra-dynamic-wallpaper",
    repo: "https://github.com/GeneralD/lyra-dynamic-wallpaper",
  },
];

const t = copy[asLocale(Astro.currentLocale)].ecosystem;
const cards = products.map((p) => ({ ...p, ...t.cards[p.key] }));
---

<section id="ecosystem" class="relative mx-auto max-w-6xl px-6 py-20 sm:py-28">
  <div class="mx-auto mb-14 max-w-2xl text-center">
    <h2
      class="font-display text-2xl font-bold uppercase tracking-tight sm:text-4xl"
      set:html={t.headingHtml}
    />
    <p class="mt-4 font-mono text-sm text-muted sm:text-base">
      {t.lead}
    </p>
  </div>

  <div class="grid gap-6 lg:grid-cols-3">
    {
      cards.map((c) => (
        <a
          href={c.repo}
          class="group flex flex-col gap-4 rounded-2xl border border-white/10 bg-surface p-7 transition hover:border-decode/40"
        >
          <EcosystemMotif surfaceKey={c.key} />
          <p class="font-mono text-xs uppercase tracking-[0.2em] text-decode">{c.surface}</p>
          {/* no whitespace between name and arrow → the arrow can never wrap alone */}
          <h3 class="font-display text-sm font-bold uppercase tracking-wide text-ink">
            {c.name}<span class="ml-1 inline-block text-muted transition-transform group-hover:translate-x-0.5">→</span>
          </h3>
          <p class="font-mono text-sm leading-relaxed text-muted">{c.body}</p>
        </a>
      ))
    }
  </div>

  <!-- full-set recommendation -->
  <div
    class="mt-6 grid gap-6 rounded-2xl border border-decode/25 bg-decode/[0.04] p-7 lg:grid-cols-2 lg:items-center"
  >
    <div>
      <h3 class="font-display text-sm font-bold uppercase tracking-wide text-decode">
        {t.recommend.heading}
      </h3>
      <p class="mt-3 font-mono text-sm leading-relaxed text-muted">{t.recommend.body}</p>
      <p class="mt-3 font-mono text-xs leading-relaxed text-faint">{t.recommend.note}</p>
    </div>
    <pre class="overflow-x-auto rounded-lg border border-white/10 bg-black/40 p-5 font-mono text-sm leading-relaxed"><code><span class="text-faint">$</span> brew tap generald/tap
<span class="text-faint">$</span> brew install lyra
<span class="text-faint">$</span> brew install --cask lyra-screensaver
<span class="text-faint">$</span> brew install lyra-dynamic-wallpaper
<span class="text-faint">$</span> <span class="text-decode">lyra-dynamic-wallpaper --apply</span></code></pre>
  </div>

  <!-- LyraKit credit — chip colour matches the companions' "built on LyraKit" README badge (#8A63D2) -->
  <div class="mt-8 flex flex-wrap items-center justify-center gap-x-3 gap-y-2 text-center">
    <a
      href="https://github.com/GeneralD/lyra/blob/main/docs/LyraKit.md"
      class="inline-flex items-center gap-1.5 rounded-full border border-[#8A63D2]/40 bg-[#8A63D2]/10 px-3 py-1 font-mono text-[11px] uppercase tracking-widest text-[#b79ce8] transition hover:border-[#8A63D2] hover:text-ink"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-[#8A63D2]"></span>
      built on LyraKit
    </a>
    <p class="font-mono text-xs text-faint">{t.lyrakit}</p>
  </div>
</section>
