---
// Benefit-first framing of Lyra's real, shipped capabilities (see app README).
// Copy lives in src/i18n/translations.ts; each card leads with a live animated
// motif (FeatureMotif) that visualises the feature — the site as its own demo.
import { asLocale, copy, type FeatureKey } from "../i18n/translations";
import FeatureMotif from "./FeatureMotif.astro";

const order: readonly FeatureKey[] = [
  "lyrics",
  "video",
  "ripple",
  "decode",
  "ai",
  "cli",
  "spectrum",
];

const t = copy[asLocale(Astro.currentLocale)].features;
const features = order.map((key) => ({ key, ...t.cards[key] }));
---

<section id="features" class="relative mx-auto max-w-6xl px-6 py-20 sm:py-28">
  <div class="mx-auto mb-14 max-w-2xl text-center">
    <h2
      class="font-display text-2xl font-bold uppercase tracking-tight sm:text-4xl"
      set:html={t.headingHtml}
    />
    <p class="mt-4 font-mono text-sm text-muted sm:text-base">
      {t.lead}
    </p>
  </div>

  <div class="grid gap-px overflow-hidden rounded-2xl border border-white/10 bg-white/10 sm:grid-cols-2 lg:grid-cols-3">
    {
      features.map((f) => (
        <div class="group flex flex-col gap-4 bg-bg p-7 transition hover:bg-surface">
          <FeatureMotif featureKey={f.key} />
          <h3 class="font-display text-sm font-bold uppercase tracking-wide text-ink">
            {f.title}
          </h3>
          <p class="font-mono text-sm leading-relaxed text-muted">{f.body}</p>
        </div>
      ))
    }
  </div>
</section>
