---
// Real product footage from the Lyra app repo (assets/demo.gif).
// Heavy (6 MB), so it lives below the fold and loads lazily — the hero above
// is pure CSS so first paint stays instant.
import { asLocale, copy } from "../i18n/translations";

const t = copy[asLocale(Astro.currentLocale)].demo;
---

<section id="demo" class="relative mx-auto max-w-6xl px-6 py-20 sm:py-28">
  <div class="mx-auto mb-12 max-w-2xl text-center">
    <h2
      class="font-display text-2xl font-bold uppercase tracking-tight sm:text-4xl"
      set:html={t.headingHtml}
    />
    <p class="mt-4 font-mono text-sm text-muted sm:text-base">
      {t.lead}
    </p>
  </div>

  <div
    class="relative overflow-hidden rounded-2xl border border-white/10 bg-surface shadow-[0_30px_80px_-20px_rgba(67,56,202,0.5)]"
  >
    <!-- faux window chrome -->
    <div class="flex items-center gap-2 border-b border-white/10 bg-black/30 px-4 py-3">
      <span class="h-3 w-3 rounded-full bg-[#ff5f57]"></span>
      <span class="h-3 w-3 rounded-full bg-[#febc2e]"></span>
      <span class="h-3 w-3 rounded-full bg-[#28c840]"></span>
      <span class="ml-3 font-mono text-xs text-faint">{t.windowLabel}</span>
    </div>
    <img
      src="/demo.gif"
      alt={t.imgAlt}
      width="1280"
      height="800"
      loading="lazy"
      decoding="async"
      class="block w-full"
    />
  </div>
</section>
