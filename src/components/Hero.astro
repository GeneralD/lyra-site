---
// CSS-only "code rain" backdrop — decorative, no JS, honours reduced-motion.
const cols = Array.from({ length: 24 }, (_, i) => {
  const left = (i / 24) * 100;
  const delay = (i * 0.37) % 6;
  const dur = 5 + ((i * 1.3) % 6);
  const glyphs = "01ライラ♪♫01アイウエオ01".repeat(6);
  return { left, delay, dur, glyphs };
});
---

<section class="relative overflow-hidden border-b border-white/5">
  <!-- code rain -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 select-none opacity-[0.12]">
    {
      cols.map((c) => (
        <span
          class="rain-col absolute top-0 font-mono text-xs leading-tight tracking-widest text-decode"
          style={`left:${c.left}%;writing-mode:vertical-rl;animation:rain ${c.dur}s linear ${c.delay}s infinite;`}
        >
          {c.glyphs}
        </span>
      ))
    }
  </div>

  <!-- radial glow -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute left-1/2 top-0 h-[42rem] w-[42rem] -translate-x-1/2 -translate-y-1/3 rounded-full opacity-40 blur-3xl"
    style="background: radial-gradient(circle, var(--color-primary) 0%, transparent 65%);"
  >
  </div>

  <div class="relative mx-auto flex max-w-5xl flex-col items-center px-6 pb-24 pt-28 text-center sm:pt-36">
    <span
      class="mb-6 inline-flex items-center gap-2 rounded-full border border-decode/30 bg-decode/5 px-4 py-1.5 font-mono text-xs uppercase tracking-[0.2em] text-decode decode-flicker"
    >
      <span class="h-1.5 w-1.5 rounded-full bg-decode"></span>
      for macOS 14+
    </span>

    <h1 class="font-display text-5xl font-bold uppercase leading-[1.05] tracking-tight sm:text-7xl">
      Your desktop,<br />
      <span class="text-lyric">set to music.</span>
    </h1>

    <p class="mt-7 max-w-2xl font-mono text-base leading-relaxed text-muted sm:text-lg">
      Lyra paints your macOS desktop with a living video wallpaper and floats
      <span class="text-ink">synced lyrics</span> right over it — decoded line by
      line, matrix-style, in real time.
    </p>

    <div class="mt-10 flex flex-col items-center gap-4 sm:flex-row">
      <a
        href="#install"
        class="group inline-flex items-center gap-2 rounded-lg bg-accent px-7 py-3.5 font-mono text-sm font-bold uppercase tracking-wider text-bg transition hover:bg-decode hover:shadow-[0_0_30px_-5px_var(--color-decode)]"
      >
        brew install lyra
        <span class="transition-transform group-hover:translate-x-0.5">→</span>
      </a>
      <a
        href="https://github.com/GeneralD/lyra"
        class="inline-flex items-center gap-2 rounded-lg border border-white/15 px-7 py-3.5 font-mono text-sm font-bold uppercase tracking-wider text-ink transition hover:border-white/40 hover:bg-white/5"
      >
        View on GitHub
      </a>
    </div>

    <p class="mt-6 font-mono text-xs text-faint">
      Free &amp; open source · Homebrew, Mint, or build from source
    </p>
  </div>
</section>
